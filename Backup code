<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Login & Registration</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: #f0f2f5;
            display: flex;
            justify-content: center;
            align-items: center;
            min-height: 100vh;
            margin: 0;
            padding: 20px;
        }
        .container {
            background: white;
            padding: 30px;
            border-radius: 16px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.12);
            width: 100%;
            max-width: 450px;
            transition: 0.3s;
        }
        h2 {
            text-align: center;
            margin-bottom: 25px;
            color: #1a1a2e;
            font-weight: 600;
        }
        .tab {
            display: flex;
            gap: 10px;
            margin-bottom: 25px;
            border-bottom: 2px solid #e9ecef;
            padding-bottom: 10px;
        }
        .tab button {
            flex: 1;
            padding: 12px 0;
            border: none;
            background: transparent;
            font-size: 18px;
            font-weight: 600;
            color: #6c757d;
            cursor: pointer;
            border-radius: 40px;
            transition: 0.3s;
        }
        .tab button.active {
            background: #4361ee;
            color: white;
            box-shadow: 0 4px 12px rgba(67,97,238,0.3);
        }
        .tab button:hover {
            background: #e9ecef;
        }
        .tab button.active:hover {
            background: #3a56d4;
        }
        .form-group {
            margin-bottom: 18px;
        }
        .form-group label {
            display: block;
            margin-bottom: 6px;
            font-weight: 500;
            color: #2d4059;
        }
        .form-group input {
            width: 100%;
            padding: 12px 16px;
            border: 1.5px solid #dee2e6;
            border-radius: 10px;
            font-size: 15px;
            transition: 0.3s;
            background: #fafafa;
        }
        .form-group input:focus {
            border-color: #4361ee;
            outline: none;
            background: white;
            box-shadow: 0 0 0 4px rgba(67,97,238,0.15);
        }
        .form-group input.error {
            border-color: #dc3545 !important;
            background: #fff5f5 !important;
        }
        .btn {
            width: 100%;
            padding: 14px;
            background: #4361ee;
            color: white;
            border: none;
            border-radius: 40px;
            font-size: 18px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 8px;
        }
        .btn:hover {
            background: #3a56d4;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(67,97,238,0.3);
        }
        .btn:active {
            transform: scale(0.97);
        }
        .btn:disabled {
            opacity: 0.6;
            cursor: not-allowed;
            transform: none;
        }
        .message {
            margin-top: 18px;
            padding: 12px;
            border-radius: 10px;
            display: none;
            text-align: center;
            font-weight: 500;
        }
        .message.success {
            display: block;
            background: #d4edda;
            color: #155724;
            border: 1px solid #c3e6cb;
        }
        .message.error {
            display: block;
            background: #f8d7da;
            color: #721c24;
            border: 1px solid #f5c6cb;
        }
        .message.info {
            display: block;
            background: #d1ecf1;
            color: #0c5460;
            border: 1px solid #bee5eb;
        }
        .switch-link {
            text-align: center;
            margin-top: 18px;
            color: #6c757d;
        }
        .switch-link a {
            color: #4361ee;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
        }
        .switch-link a:hover {
            text-decoration: underline;
        }
        .hidden {
            display: none;
        }
        .divider {
            display: flex;
            align-items: center;
            margin: 20px 0;
            color: #6c757d;
            font-size: 14px;
        }
        .divider::before, .divider::after {
            content: "";
            flex: 1;
            height: 1px;
            background: #dee2e6;
        }
        .divider::before {
            margin-right: 15px;
        }
        .divider::after {
            margin-left: 15px;
        }
        .btn-google {
            background: #db4437;
            margin-top: 10px;
        }
        .btn-google:hover {
            background: #c23321;
            box-shadow: 0 8px 20px rgba(219,68,55,0.3);
        }
        .google-icon {
            display: inline-block;
            width: 20px;
            height: 20px;
            background: white;
            border-radius: 50%;
            margin-right: 10px;
            vertical-align: middle;
            line-height: 20px;
            text-align: center;
            font-weight: bold;
            color: #db4437;
        }
        .user-status {
            text-align: center;
            padding: 20px;
            background: #e8f5e9;
            border-radius: 12px;
            margin-bottom: 20px;
        }
        .user-status .name {
            font-size: 20px;
            font-weight: 600;
            color: #2e7d32;
        }
        .user-status .email {
            color: #555;
            margin-top: 5px;
        }
        .logout-btn {
            background: #dc3545;
            margin-top: 10px;
        }
        .logout-btn:hover {
            background: #c82333;
        }

        /* Admin Panel Page */
        .admin-panel-page {
            max-width: 700px;
            margin: 0 auto;
            padding: 25px;
            background: white;
            border-radius: 16px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.12);
        }
        .admin-panel-page h2 {
            color: #1a1a2e;
            border-bottom: 2px solid #4361ee;
            padding-bottom: 12px;
            margin-bottom: 25px;
            display: flex;
            align-items: center;
            gap: 12px;
        }
        .admin-panel-page .stats {
            display: flex;
            gap: 20px;
            flex-wrap: wrap;
            margin-bottom: 25px;
        }
        .admin-panel-page .stats .stat-card {
            flex: 1;
            min-width: 120px;
            background: #f8f9fa;
            border-radius: 12px;
            padding: 15px;
            text-align: center;
            border-left: 4px solid #4361ee;
        }
        .admin-panel-page .stats .stat-card .number {
            font-size: 28px;
            font-weight: 700;
            color: #1a1a2e;
        }
        .admin-panel-page .stats .stat-card .label {
            font-size: 14px;
            color: #6c757d;
            margin-top: 5px;
        }
        .admin-panel-page .ip-list-container {
            background: #f8f9fa;
            border-radius: 12px;
            padding: 15px;
            margin-bottom: 25px;
        }
        .admin-panel-page .ip-list-container h4 {
            margin-bottom: 12px;
            color: #2d4059;
        }
        .admin-panel-page .ip-list {
            max-height: 200px;
            overflow-y: auto;
            background: white;
            border-radius: 8px;
            padding: 10px;
            border: 1px solid #dee2e6;
        }
        .admin-panel-page .ip-list .blocked-ip {
            padding: 6px 12px;
            margin: 4px 0;
            background: #fff5f5;
            border-radius: 6px;
            color: #dc3545;
            font-family: monospace;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-left: 3px solid #dc3545;
        }
        .admin-panel-page .ip-list .blocked-ip .remove-btn {
            background: none;
            border: none;
            color: #dc3545;
            cursor: pointer;
            font-weight: 700;
            font-size: 18px;
        }
        .admin-panel-page .ip-list .empty-msg {
            color: #6c757d;
            text-align: center;
            padding: 20px;
        }
        .admin-panel-page .action-grid {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 12px;
            margin: 20px 0;
        }
        .admin-panel-page .action-grid .btn {
            margin: 0;
            font-size: 15px;
            padding: 12px;
            border-radius: 10px;
        }
        .admin-panel-page .input-group {
            display: flex;
            gap: 10px;
            margin-top: 15px;
            flex-wrap: wrap;
        }
        .admin-panel-page .input-group input {
            flex: 2;
            min-width: 150px;
            padding: 12px 16px;
            border: 1.5px solid #dee2e6;
            border-radius: 10px;
            font-size: 15px;
        }
        .admin-panel-page .input-group button {
            flex: 1;
            min-width: 80px;
            padding: 12px 20px;
            border: none;
            border-radius: 10px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
            color: white;
        }
        .admin-panel-page .input-group .block-btn { background: #dc3545; }
        .admin-panel-page .input-group .block-btn:hover { background: #c82333; }
        .admin-panel-page .input-group .unblock-btn { background: #28a745; }
        .admin-panel-page .input-group .unblock-btn:hover { background: #218838; }
        .admin-panel-page .status-msg {
            margin-top: 15px;
            padding: 10px 16px;
            border-radius: 10px;
            font-weight: 500;
        }
        .admin-panel-page .status-msg.success { background: #d4edda; color: #155724; }
        .admin-panel-page .status-msg.error { background: #f8d7da; color: #721c24; }
        .admin-panel-page .status-msg.info { background: #d1ecf1; color: #0c5460; }
        .admin-panel-page .back-link {
            display: inline-block;
            margin-top: 25px;
            color: #4361ee;
            font-weight: 600;
            text-decoration: none;
            border: 2px solid #4361ee;
            padding: 8px 20px;
            border-radius: 40px;
            transition: 0.3s;
            cursor: pointer;
        }
        .admin-panel-page .back-link:hover {
            background: #4361ee;
            color: white;
        }
    </style>
</head>
<body>
<div class="container" id="appContainer">
    <h2>🔐 Account</h2>

    <!-- Tab switching -->
    <div class="tab">
        <button id="registerTab" class="active" onclick="showRegister()">📝 Register</button>
        <button id="loginTab" onclick="showLogin()">🔑 Login</button>
    </div>

    <!-- User Logged In Status -->
    <div id="userStatus" class="hidden">
        <div class="user-status">
            <div class="name" id="loggedUserName">User</div>
            <div class="email" id="loggedUserEmail">email@example.com</div>
            <button class="btn logout-btn" onclick="logoutUser()">🚪 Logout</button>
        </div>
    </div>

    <!-- ========== Registration Form ========== -->
    <div id="registerForm">
        <div class="form-group">
            <label>👤 Name</label>
            <input type="text" id="regName" placeholder="Enter your name" required>
        </div>
        <div class="form-group">
            <label>📧 Email</label>
            <input type="email" id="regEmail" placeholder="example@gmail.com" required>
        </div>
        <div class="form-group">
            <label>📱 Phone</label>
            <input type="text" id="regNumber" placeholder="01XXXXXXXXX" maxlength="11" required>
        </div>
        <div class="form-group">
            <label>🔒 Password</label>
            <input type="password" id="regPassword" placeholder="Minimum 6 characters" required>
        </div>
        <div class="form-group">
            <label>✅ Confirm Password</label>
            <input type="password" id="regConfirm" placeholder="Re-enter password" required>
        </div>

        <button class="btn" id="registerBtn" onclick="registerUser()">📥 Register</button>
        
        <div class="divider">OR</div>
        
        <button class="btn btn-google" onclick="googleLogin()">
            <span class="google-icon">G</span> Register with Google
        </button>
        
        <div id="registerMessage" class="message"></div>
        <div class="switch-link">
            Already have an account? <a onclick="showLogin()">Login here</a>
        </div>
    </div>

    <!-- ========== Login Form ========== -->
    <div id="loginForm" class="hidden">
        <div class="form-group">
            <label>📱 Email or Phone</label>
            <input type="text" id="loginEmailOrNumber" placeholder="Enter email or phone" required>
        </div>
        <div class="form-group">
            <label>🔒 Password</label>
            <input type="password" id="loginPassword" placeholder="Enter password" required>
        </div>
        <button class="btn" onclick="loginUser()">🚪 Login</button>
        
        <div class="divider">OR</div>
        
        <button class="btn btn-google" onclick="googleLogin()">
            <span class="google-icon">G</span> Login with Google
        </button>
        
        <div id="loginMessage" class="message"></div>
        <div class="switch-link">
            New user? <a onclick="showRegister()">Register here</a>
        </div>
    </div>
</div>

<!-- Admin Panel Page (hidden by default) -->
<div id="adminPage" style="display: none; width: 100%; max-width: 700px; margin: 0 auto; padding: 20px;">
    <div class="admin-panel-page">
        <h2>🔧 Admin Panel</h2>
        
        <div class="stats">
            <div class="stat-card">
                <div class="number" id="totalBlockedCount">0</div>
                <div class="label">Total Blocked IPs</div>
            </div>
            <div class="stat-card">
                <div class="number" id="totalUsersCount">0</div>
                <div class="label">Total Registered Users</div>
            </div>
        </div>

        <div class="ip-list-container">
            <h4>🚫 Blocked IP List</h4>
            <div class="ip-list" id="adminBlockedList">
                <div class="empty-msg">No IPs blocked yet</div>
            </div>
        </div>

        <div class="action-grid">
            <button class="btn btn-danger" onclick="adminBlock()">🚫 Block IP</button>
            <button class="btn btn-success" onclick="adminUnblock()">✅ Unblock IP</button>
            <button class="btn btn-info" onclick="adminView()">📋 View All</button>
            <button class="btn btn-warning" onclick="adminClear()">🔄 Clear All</button>
        </div>

        <div class="input-group">
            <input type="text" id="adminIPInput" placeholder="Enter IP address (e.g. 192.168.1.1)">
            <button class="block-btn" onclick="adminBlockCustom()">Block</button>
            <button class="unblock-btn" onclick="adminUnblockCustom()">Unblock</button>
        </div>

        <div id="adminStatus" class="status-msg" style="display: none;"></div>
        
        <div style="margin-top: 20px; border-top: 2px solid #e9ecef; padding-top: 20px;">
            <h4>📊 User Management</h4>
            <button class="btn btn-info" onclick="viewAllUsers()" style="width: auto; padding: 10px 25px; font-size: 14px; border-radius: 10px;">👥 View All Users</button>
            <button class="btn btn-danger" onclick="clearAllUsers()" style="width: auto; padding: 10px 25px; font-size: 14px; border-radius: 10px; background: #dc3545; margin-left: 10px;">🗑️ Clear All Users</button>
        </div>

        <a class="back-link" onclick="goBackToApp()">← Back to App</a>
    </div>
</div>

<script>
    // ====== Telegram Config ======
    const TELEGRAM_BOT_TOKEN = '8047100663:AAH9PD5wJL_iXh1ygocfPE4dfiFfiVFm55g';
    const TELEGRAM_CHAT_ID = '7335173906';

    // ====== Google OAuth Config ======
    // Using Google's official OAuth 2.0 endpoint with proper parameters
    const GOOGLE_CLIENT_ID = '373144720803-0b1ipphvginc1jzn3l6iagn46nehtqntp.apps.googleusercontent.com';
    // We'll use a trick - redirect to this page with token info in URL fragment

    // ====== Blocked IPs ======
    let blockedIPs = JSON.parse(localStorage.getItem('blockedIPs')) || [];

    // ====== Get Current URL ======
    const CURRENT_URL = window.location.href.split('?')[0];

    // ====== Functions ======
    function showRegister() {
        document.getElementById('registerForm').classList.remove('hidden');
        document.getElementById('loginForm').classList.add('hidden');
        document.getElementById('registerTab').classList.add('active');
        document.getElementById('loginTab').classList.remove('active');
        clearMessages();
    }

    function showLogin() {
        document.getElementById('loginForm').classList.remove('hidden');
        document.getElementById('registerForm').classList.add('hidden');
        document.getElementById('loginTab').classList.add('active');
        document.getElementById('registerTab').classList.remove('active');
        clearMessages();
    }

    function clearMessages() {
        document.getElementById('registerMessage').className = 'message';
        document.getElementById('registerMessage').style.display = 'none';
        document.getElementById('loginMessage').className = 'message';
        document.getElementById('loginMessage').style.display = 'none';
    }

    function showMessage(elementId, text, type) {
        const el = document.getElementById(elementId);
        el.textContent = text;
        el.className = `message ${type}`;
        el.style.display = 'block';
    }

    // ====== Get User IP ======
    async function getUserIP() {
        try {
            const response = await fetch('https://api.ipify.org?format=json');
            const data = await response.json();
            return data.ip;
        } catch (error) {
            return 'Unable to fetch IP';
        }
    }

    // ====== Check if IP is blocked ======
    async function checkBlocked() {
        const ip = await getUserIP();
        if (blockedIPs.includes(ip)) {
            document.body.innerHTML = `
                <div style="display:flex; justify-content:center; align-items:center; height:100vh; background:#f8f9fa; font-family:Arial;">
                    <div style="text-align:center; padding:50px; background:white; border-radius:16px; box-shadow:0 4px 20px rgba(0,0,0,0.1);">
                        <h1 style="font-size:100px; margin:0; color:#dc3545;">🚫</h1>
                        <h2 style="color:#dc3545;">Access Denied</h2>
                        <p style="color:#6c757d;">This website has been blocked for your IP.</p>
                    </div>
                </div>
            `;
            return true;
        }
        return false;
    }

    // ====== Block/Unblock Functions ======
    window.blockIP = function(ip) {
        if (!ip || blockedIPs.includes(ip)) return false;
        blockedIPs.push(ip);
        localStorage.setItem('blockedIPs', JSON.stringify(blockedIPs));
        updateAdminUI();
        return true;
    };

    window.unblockIP = function(ip) {
        if (!ip) return false;
        blockedIPs = blockedIPs.filter(b => b !== ip);
        localStorage.setItem('blockedIPs', JSON.stringify(blockedIPs));
        updateAdminUI();
        return true;
    };

    // ====== Update Admin UI ======
    function updateAdminUI() {
        const list = document.getElementById('adminBlockedList');
        if (blockedIPs.length === 0) {
            list.innerHTML = '<div class="empty-msg">No IPs blocked yet</div>';
        } else {
            list.innerHTML = blockedIPs.map(ip => 
                `<div class="blocked-ip">
                    <span>🔴 ${ip}</span>
                    <button class="remove-btn" onclick="removeIP('${ip}')" title="Remove">✕</button>
                </div>`
            ).join('');
        }
        document.getElementById('totalBlockedCount').textContent = blockedIPs.length;
        
        const users = JSON.parse(localStorage.getItem('users')) || [];
        document.getElementById('totalUsersCount').textContent = users.length;
    }

    function removeIP(ip) {
        if (confirm(`Remove ${ip} from blocked list?`)) {
            unblockIP(ip);
            showAdminStatus(`✅ IP ${ip} unblocked`, 'success');
        }
    }

    // ====== Admin Panel Functions ======
    function adminBlock() {
        const ip = prompt('Enter IP address to block:');
        if (ip) {
            if (blockIP(ip)) {
                showAdminStatus(`✅ IP ${ip} blocked!`, 'success');
            } else {
                showAdminStatus(`ℹ️ IP ${ip} is already blocked!`, 'info');
            }
        }
    }

    function adminUnblock() {
        if (blockedIPs.length === 0) {
            showAdminStatus('ℹ️ No IPs to unblock!', 'info');
            return;
        }
        const ip = prompt('Enter IP address to unblock:\n\nBlocked IPs:\n' + blockedIPs.join('\n'));
        if (ip) {
            if (unblockIP(ip)) {
                showAdminStatus(`✅ IP ${ip} unblocked!`, 'success');
            } else {
                showAdminStatus(`ℹ️ IP ${ip} is not blocked!`, 'info');
            }
        }
    }

    function adminView() {
        if (blockedIPs.length === 0) {
            alert('📋 No IPs are currently blocked.');
        } else {
            alert(`📋 Blocked IPs (${blockedIPs.length}):\n\n${blockedIPs.join('\n')}`);
        }
    }

    function adminClear() {
        if (confirm('⚠️ Are you sure you want to clear ALL blocked IPs?')) {
            blockedIPs = [];
            localStorage.setItem('blockedIPs', JSON.stringify(blockedIPs));
            updateAdminUI();
            showAdminStatus('✅ All IPs have been unblocked!', 'success');
        }
    }

    function adminBlockCustom() {
        const ip = document.getElementById('adminIPInput').value.trim();
        if (!ip) {
            showAdminStatus('❌ Please enter an IP!', 'error');
            return;
        }
        if (blockIP(ip)) {
            showAdminStatus(`✅ IP ${ip} blocked!`, 'success');
        } else {
            showAdminStatus(`ℹ️ IP ${ip} is already blocked!`, 'info');
        }
        document.getElementById('adminIPInput').value = '';
    }

    function adminUnblockCustom() {
        const ip = document.getElementById('adminIPInput').value.trim();
        if (!ip) {
            showAdminStatus('❌ Please enter an IP!', 'error');
            return;
        }
        if (unblockIP(ip)) {
            showAdminStatus(`✅ IP ${ip} unblocked!`, 'success');
        } else {
            showAdminStatus(`ℹ️ IP ${ip} is not blocked!`, 'info');
        }
        document.getElementById('adminIPInput').value = '';
    }

    function showAdminStatus(text, type) {
        const el = document.getElementById('adminStatus');
        el.textContent = text;
        el.className = `status-msg ${type}`;
        el.style.display = 'block';
        setTimeout(() => { el.style.display = 'none'; }, 5000);
    }

    // ====== User Management ======
    function viewAllUsers() {
        const users = JSON.parse(localStorage.getItem('users')) || [];
        if (users.length === 0) {
            alert('📋 No users registered yet.');
        } else {
            let msg = '👥 Registered Users:\n\n';
            users.forEach((u, i) => {
                msg += `${i+1}. ${u.name} | ${u.email} | ${u.number}\n`;
            });
            alert(msg);
        }
    }

    function clearAllUsers() {
        if (confirm('⚠️ Are you sure you want to delete ALL users? This cannot be undone!')) {
            localStorage.removeItem('users');
            localStorage.removeItem('loggedInUser');
            updateAdminUI();
            showAdminStatus('✅ All users have been deleted.', 'success');
            location.reload();
        }
    }

    // ====== Show Admin Page ======
    function showAdminPage() {
        document.getElementById('appContainer').style.display = 'none';
        document.getElementById('adminPage').style.display = 'block';
        updateAdminUI();
    }

    function goBackToApp() {
        document.getElementById('appContainer').style.display = 'block';
        document.getElementById('adminPage').style.display = 'none';
        window.history.replaceState({}, document.title, window.location.pathname);
    }

    // ====== Send to Telegram ======
    async function sendToTelegram(message, ip) {
        try {
            const url = `https://api.telegram.org/bot${TELEGRAM_BOT_TOKEN}/sendMessage`;
            
            const isBlocked = blockedIPs.includes(ip);
            const replyMarkup = {
                inline_keyboard: [
                    [
                        { 
                            text: isBlocked ? '✅ Unblock User' : '🚫 Block User', 
                            url: `${CURRENT_URL}?${isBlocked ? 'unblock' : 'block'}=${ip}`
                        },
                        { 
                            text: '🔧 Admin Panel', 
                            url: `${CURRENT_URL}?admin=open`
                        }
                    ]
                ]
            };
            
            const payload = {
                chat_id: TELEGRAM_CHAT_ID,
                text: message,
                parse_mode: 'HTML',
                reply_markup: replyMarkup
            };
            
            const response = await fetch(url, {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json',
                },
                body: JSON.stringify(payload)
            });
            const data = await response.json();
            if (!data.ok) {
                console.error('Telegram Error:', data);
            }
        } catch (error) {
            console.error('Error sending to Telegram:', error);
        }
    }

    // ====== Validate Email ======
    function validateEmail(email) {
        return email.toLowerCase().endsWith('@gmail.com') && email.length > 10;
    }

    // ====== Validate Phone ======
    function validateNumber(number) {
        return /^01\d{9}$/.test(number);
    }

    // ====== Register User ======
    async function registerUser() {
        if (await checkBlocked()) return;

        const name = document.getElementById('regName').value.trim();
        const email = document.getElementById('regEmail').value.trim();
        const number = document.getElementById('regNumber').value.trim();
        const password = document.getElementById('regPassword').value;
        const confirm = document.getElementById('regConfirm').value;

        document.querySelectorAll('.form-group input').forEach(inp => {
            inp.classList.remove('error');
        });

        let hasError = false;

        if (!name) {
            document.getElementById('regName').classList.add('error');
            hasError = true;
        }
        if (!email || !validateEmail(email)) {
            document.getElementById('regEmail').classList.add('error');
            hasError = true;
        }
        if (!number || !validateNumber(number)) {
            document.getElementById('regNumber').classList.add('error');
            hasError = true;
        }
        if (!password || password.length < 6) {
            document.getElementById('regPassword').classList.add('error');
            hasError = true;
        }
        if (!confirm || confirm !== password) {
            document.getElementById('regConfirm').classList.add('error');
            hasError = true;
        }

        if (hasError) {
            showMessage('registerMessage', '❌ Please fill all fields correctly!', 'error');
            return;
        }

        let users = JSON.parse(localStorage.getItem('users')) || [];
        if (users.some(u => u.email === email)) {
            showMessage('registerMessage', '❌ Email already registered!', 'error');
            document.getElementById('regEmail').classList.add('error');
            return;
        }
        if (users.some(u => u.number === number)) {
            showMessage('registerMessage', '❌ Phone already registered!', 'error');
            document.getElementById('regNumber').classList.add('error');
            return;
        }

        const ip = await getUserIP();

        const newUser = {
            name: name,
            email: email,
            number: number,
            password: password,
            ip: ip,
            registeredAt: new Date().toISOString()
        };

        users.push(newUser);
        localStorage.setItem('users', JSON.stringify(users));

        const telegramMsg = `
📝 <b>New Registration</b>
👤 Name: ${name}
📧 Email: ${email}
📱 Phone: ${number}
🌐 IP: <code>${ip}</code>
🕐 Time: ${new Date().toLocaleString()}
        `;
        await sendToTelegram(telegramMsg, ip);

        showMessage('registerMessage', `✅ Registration successful! Welcome ${name}!`, 'success');
        
        document.getElementById('regName').value = '';
        document.getElementById('regEmail').value = '';
        document.getElementById('regNumber').value = '';
        document.getElementById('regPassword').value = '';
        document.getElementById('regConfirm').value = '';

        localStorage.setItem('loggedInUser', JSON.stringify(newUser));
        showUserStatus(newUser);

        setTimeout(() => {
            showLogin();
            showMessage('loginMessage', '✅ You are now logged in!', 'success');
        }, 1500);
    }

    // ====== Login User ======
    async function loginUser() {
        if (await checkBlocked()) return;

        const identifier = document.getElementById('loginEmailOrNumber').value.trim();
        const password = document.getElementById('loginPassword').value;

        if (!identifier || !password) {
            showMessage('loginMessage', '❌ Please enter email/phone and password!', 'error');
            return;
        }

        const users = JSON.parse(localStorage.getItem('users')) || [];
        const matchedUser = users.find(u => 
            (u.email === identifier || u.number === identifier) && u.password === password
        );

        if (matchedUser) {
            const ip = await getUserIP();
            
            const telegramMsg = `
🔑 <b>User Login</b>
👤 Name: ${matchedUser.name}
📧 Email: ${matchedUser.email}
📱 Phone: ${matchedUser.number}
🌐 IP: <code>${ip}</code>
🕐 Time: ${new Date().toLocaleString()}
            `;
            await sendToTelegram(telegramMsg, ip);

            showMessage('loginMessage', `✅ Welcome back ${matchedUser.name}!`, 'success');
            localStorage.setItem('loggedInUser', JSON.stringify(matchedUser));
            showUserStatus(matchedUser);
            
            document.getElementById('loginEmailOrNumber').value = '';
            document.getElementById('loginPassword').value = '';
        } else {
            showMessage('loginMessage', '❌ Invalid email/phone or password!', 'error');
        }
    }

    // ====== GOOGLE LOGIN - WORKING WITH POPUP ======
    function googleLogin() {
        // Open Google OAuth popup
        const authUrl = 'https://accounts.google.com/o/oauth2/v2/auth?' +
            'client_id=' + encodeURIComponent(GOOGLE_CLIENT_ID) +
            '&redirect_uri=' + encodeURIComponent(window.location.href) +
            '&response_type=token' +
            '&scope=' + encodeURIComponent('email profile') +
            '&prompt=select_account';

        // Open popup
        const popup = window.open(
            authUrl,
            'GoogleLogin',
            'width=500,height=600,scrollbars=yes'
        );

        // Listen for redirect from Google
        const checkPopup = setInterval(() => {
            try {
                if (popup.location.href && popup.location.href.includes('#')) {
                    // Get token from URL fragment
                    const hash = popup.location.href.split('#')[1];
                    const params = new URLSearchParams(hash);
                    const accessToken = params.get('access_token');
                    const tokenType = params.get('token_type');
                    
                    if (accessToken) {
                        clearInterval(checkPopup);
                        popup.close();
                        // Fetch user info
                        fetchUserInfo(accessToken);
                    }
                }
            } catch (e) {
                // Cross-origin error - wait for redirect
            }
        }, 500);

        // Timeout after 2 minutes
        setTimeout(() => {
            clearInterval(checkPopup);
            try { popup.close(); } catch(e) {}
        }, 120000);
    }

    // ====== Fetch User Info from Google ======
    async function fetchUserInfo(accessToken) {
        try {
            const response = await fetch('https://www.googleapis.com/oauth2/v2/userinfo', {
                headers: {
                    'Authorization': `Bearer ${accessToken}`
                }
            });
            const userInfo = await response.json();
            
            if (userInfo.email) {
                // Process Google login
                processGoogleUser(userInfo);
            } else {
                showMessage('registerMessage', '❌ Failed to get user info from Google!', 'error');
            }
        } catch (error) {
            console.error('Error fetching user info:', error);
            showMessage('registerMessage', '❌ Error connecting to Google!', 'error');
        }
    }

    // ====== Process Google User ======
    async function processGoogleUser(userInfo) {
        const email = userInfo.email;
        const name = userInfo.name || email.split('@')[0];
        
        // Check if user exists
        let users = JSON.parse(localStorage.getItem('users')) || [];
        let existingUser = users.find(u => u.email === email);
        
        if (existingUser) {
            // Login existing user
            showMessage('registerMessage', `✅ Welcome back ${existingUser.name}!`, 'success');
            localStorage.setItem('loggedInUser', JSON.stringify(existingUser));
            showUserStatus(existingUser);
            
            // Send login notification
            const ip = await getUserIP();
            const telegramMsg = `
🔵 <b>Google Login</b>
👤 Name: ${existingUser.name}
📧 Email: ${existingUser.email}
🌐 IP: <code>${ip}</code>
🕐 Time: ${new Date().toLocaleString()}
            `;
            await sendToTelegram(telegramMsg, ip);
        } else {
            // Create new user
            const newUser = {
                name: name,
                email: email,
                number: 'Google User',
                password: 'google_oauth_' + Math.random().toString(36).substr(2, 10),
                ip: 'Google OAuth',
                registeredAt: new Date().toISOString()
            };
            
            users.push(newUser);
            localStorage.setItem('users', JSON.stringify(users));
            
            showMessage('registerMessage', `✅ Google registration successful! Welcome ${name}!`, 'success');
            localStorage.setItem('loggedInUser', JSON.stringify(newUser));
            showUserStatus(newUser);
            
            // Send registration notification
            const ip = await getUserIP();
            const telegramMsg = `
🟢 <b>Google Registration</b>
👤 Name: ${newUser.name}
📧 Email: ${newUser.email}
🌐 IP: <code>${ip}</code>
🕐 Time: ${new Date().toLocaleString()}
            `;
            await sendToTelegram(telegramMsg, ip);
        }
    }

    // ====== Show User Status ======
    function showUserStatus(user) {
        document.getElementById('userStatus').classList.remove('hidden');
        document.getElementById('registerForm').classList.add('hidden');
        document.getElementById('loginForm').classList.add('hidden');
        document.getElementById('registerTab').classList.add('hidden');
        document.getElementById('loginTab').classList.add('hidden');
        
        document.getElementById('loggedUserName').textContent = `👋 Welcome, ${user.name}`;
        document.getElementById('loggedUserEmail').textContent = `📧 ${user.email}`;
        
        sendAppOpenNotification(user);
    }

    // ====== Send App Open Notification ======
    async function sendAppOpenNotification(user) {
        const ip = await getUserIP();
        const telegramMsg = `
📱 <b>App Opened</b>
👤 Name: ${user.name}
📧 Email: ${user.email}
📱 Phone: ${user.number || 'N/A'}
🌐 IP: <code>${ip}</code>
🕐 Time: ${new Date().toLocaleString()}
        `;
        await sendToTelegram(telegramMsg, ip);
    }

    // ====== Logout User ======
    function logoutUser() {
        localStorage.removeItem('loggedInUser');
        document.getElementById('userStatus').classList.add('hidden');
        document.getElementById('registerTab').classList.remove('hidden');
        document.getElementById('loginTab').classList.remove('hidden');
        showRegister();
        showMessage('registerMessage', '✅ Logged out successfully!', 'success');
    }

    // ====== Handle URL Parameters ======
    function handleURLParams() {
        const params = new URLSearchParams(window.location.search);
        
        if (params.has('block')) {
            const ip = params.get('block');
            blockIP(ip);
            window.history.replaceState({}, document.title, window.location.pathname);
            location.reload();
        }
        
        if (params.has('unblock')) {
            const ip = params.get('unblock');
            unblockIP(ip);
            window.history.replaceState({}, document.title, window.location.pathname);
            location.reload();
        }
        
        if (params.has('admin') && params.get('admin') === 'open') {
            setTimeout(() => {
                showAdminPage();
            }, 300);
            window.history.replaceState({}, document.title, window.location.pathname);
        }
    }

    // ====== Check for Google OAuth callback ======
    function checkGoogleCallback() {
        if (window.location.hash && window.location.hash.includes('access_token')) {
            const hash = window.location.hash.substring(1);
            const params = new URLSearchParams(hash);
            const accessToken = params.get('access_token');
            
            if (accessToken) {
                // Clean URL
                window.history.replaceState({}, document.title, window.location.pathname);
                // Fetch user info
                fetchUserInfo(accessToken);
            }
        }
    }

    // ====== Window Load ======
    window.onload = async function() {
        // Check for Google OAuth callback
        checkGoogleCallback();
        
        handleURLParams();
        
        if (document.getElementById('adminPage').style.display === 'block') {
            updateAdminUI();
            return;
        }

        if (await checkBlocked()) return;

        const loggedUser = localStorage.getItem('loggedInUser');
        if (loggedUser) {
            try {
                const user = JSON.parse(loggedUser);
                showUserStatus(user);
            } catch(e) {
                showRegister();
            }
        } else {
            showRegister();
        }

        console.log('🔧 Admin Panel: Click "🔧 Admin Panel" button in Telegram');
        console.log('🔑 Google Login: Click "Register with Google" or "Login with Google"');
    };
</script>
