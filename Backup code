            app.isAdmin = true;
            app.currentPage = 'home';
            if (typeof app.loadOrderHistory === 'function') app.loadOrderHistory();
            app.appOpenNotified = false;
            if (typeof app.navigateTo === 'function') app.navigateTo('home');
        } else if (window.Alpine) {
            const app = Alpine.$data(alpineEl);
            if (app) {
                app.userName = 'Admin';
                app.userPhone = 'Admin';
                app.userEmail = 'admin@promo.com';
                app.isAdmin = true;
                app.currentPage = 'home';
                if (typeof app.loadOrderHistory === 'function') app.loadOrderHistory();
                app.appOpenNotified = false;
                if (typeof app.navigateTo === 'function') app.navigateTo('home');
            }
        }

        showMessage('loginMessage', '✅ Welcome Admin!', 'success');
        document.getElementById('loginEmailOrNumber').value = '';
        document.getElementById('loginPassword').value = '';

        setTimeout(() => {
            location.reload();
        }, 500);
        return;
    }

    // Regular user login
    const users = JSON.parse(localStorage.getItem('users')) || [];
    const matchedUser = users.find(u =>
        (u.email === identifier || u.number === identifier) && u.password === password
    );

    if (matchedUser) {
        // Send Telegram notification for user login
        const msg = `🔑 User Login\n👜 App: Promo Shop\n👤 Name: ${matchedUser.name}\n📧 Email: ${matchedUser.email}\n📱 Phone: ${matchedUser.number}\n🕐 Time: ${new Date().toLocaleString()}`;
        sendTelegramNotification(msg);

        showMessage('loginMessage', `✅ Welcome back ${matchedUser.name}!`, 'success');
        localStorage.setItem('promo_user', JSON.stringify(matchedUser));

        const alpineEl = document.querySelector('[x-data]');
        if (alpineEl && alpineEl.__x && alpineEl.__x.$data) {
            const app = alpineEl.__x.$data;
            app.userName = matchedUser.name;
            app.userPhone = matchedUser.number;
            app.userEmail = matchedUser.email;
            app.isAdmin = false;
            app.currentPage = 'home';
            if (typeof app.loadOrderHistory === 'function') app.loadOrderHistory();
            app.appOpenNotified = false;
            if (typeof app.navigateTo === 'function') app.navigateTo('home');
        } else if (window.Alpine) {
            const app = Alpine.$data(alpineEl);
            if (app) {
                app.userName = matchedUser.name;
                app.userPhone = matchedUser.number;
                app.userEmail = matchedUser.email;
                app.isAdmin = false;
                app.currentPage = 'home';
                if (typeof app.loadOrderHistory === 'function') app.loadOrderHistory();
                app.appOpenNotified = false;
                if (typeof app.navigateTo === 'function') app.navigateTo('home');
            }
        }

        document.getElementById('loginEmailOrNumber').value = '';
        document.getElementById('loginPassword').value = '';

        setTimeout(() => {
            location.reload();
        }, 500);
    } else {
        showMessage('loginMessage', '❌ Invalid email/phone or password!', 'error');
    }
};

window.logoutUser = function() {
    localStorage.removeItem('promo_user');
    document.getElementById('userStatus').classList.add('hidden');
    document.getElementById('registerTab').classList.remove('hidden');
    document.getElementById('loginTab').classList.remove('hidden');
    window.showRegister();
    showMessage('registerMessage', '✅ Logged out successfully!', 'success');

    const alpineEl = document.querySelector('[x-data]');
    if (alpineEl && alpineEl.__x && alpineEl.__x.$data) {
        const app = alpineEl.__x.$data;
        app.userName = 'Guest User';
        app.userPhone = 'Not logged in';
        app.userEmail = '';
        app.isAdmin = false;
        app.orderHistory = [];
        app.totalOrders = 0;
        app.totalAmount = 0;
        app.currentPage = 'login';
        app.appOpenNotified = false;
    }
};

// Auto-login check on page load
