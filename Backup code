                async searchYtChannel() {
                    const value = this.ytHandleInput.trim();
                    if(!value || value === "@") { this.ytSearchError = "Please enter a valid channel handle."; return; }
                    
                    let cleanHandle = value.startsWith('@') ? value : '@' + value;
                    this.ytSearchError = '';
                    this.isYtSearching = true;

                    try {
                        const url = `https://www.googleapis.com/youtube/v3/channels?part=snippet,statistics&forHandle=${encodeURIComponent(cleanHandle)}&key=${this.ytApiKey}`;
                        const response = await fetch(url);
                        const data = await response.json();

                        if (!data.items || data.items.length === 0) {
                            this.ytSearchError = "Channel not found! Check the handle.";
                            this.isYtSearching = false;
                            return;
                        }

                        const channel = data.items[0];
                        const title = channel.snippet.title;
                        const avatar = channel.snippet.thumbnails.default?.url || '';
                        const stats = channel.statistics;

                        this.ytChannelData = {
                            title: title,
                            handle: cleanHandle,
                            avatar: avatar,
                            subs: this.formatYtNum(stats.subscriberCount),
                            videos: this.formatYtNum(stats.videoCount),
                            views: this.formatYtNum(stats.viewCount)
