                parseGlobalConfig() {
                    if (this.configToken && this.configToken.includes('-')) {
                        const chunks = this.configToken.split('-');
                        this.discountSettings.mode = chunks[0].trim().toLowerCase();
                        this.discountSettings.percent = parseFloat(chunks[1]) || 0;
                    }
                },

                calcPriceOnSite(basePrice) {
                    return Math.round(basePrice * (1 - this.discountSettings.percent / 100));
                },

                calcCheckoutPrice(basePrice, typedPromoCode = "") {
                    if (this.discountSettings.mode === 'on') {
                        return Math.round(basePrice * (1 - this.discountSettings.percent / 100));
                    }
                    if (this.discountSettings.mode === 'off' && typedPromoCode.trim() === this.getLivePromoCode()) {
                        return Math.round(basePrice * (1 - this.discountSettings.percent / 100));
                    }
                    return basePrice;
                },

