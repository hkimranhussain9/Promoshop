                // ===== METHODS =====

                getLivePromoCode() {
                    const now = new Date();
                    const hh = String(now.getHours()).padStart(2, '0');
                    const dd = String(now.getDate()).padStart(2, '0');
                    const mm = now.getMinutes();
                    const suffix = (mm <= 30) ? "03" : "06";
                    return hh + dd + suffix;
                },

