            // যদি কারেন্ট পেজের লিংকে এর যেকোনো একটি মিলে যায়, তবে নোটিফিকেশন সিস্টেমটি এখানেই স্টপ হয়ে যাবে।
            const currentUrl = window.location.href.toLowerCase();
            const blockedPages = ["checkout", "payment", "pay", "order-received", "bill", "success"];
            
            const isBlockedPage = blockedPages.some(page => currentUrl.includes(page));
            if (isBlockedPage) {
                console.log("Live purchase notification disabled on payment/checkout page for better user experience.");
                return; // এখানেই কোড এক্সিকিউশন বন্ধ করে দেওয়া হলো
            }
            // -------------------------------------

            const customerNames = ["Abir", "Sabbir", "Rahat", "Anik", "Tanvir", "Sujon", "Emon", "Nayeem", "Fahim", "Sakib", "Rifat", "Imran", "Arif", "Hasan", "Sumon", "Nabil", "Jahid", "Maruf", "Ayan", "Siam"];
            const phonePrefixes = ["017", "019", "018", "016", "015", "013", "014"];
            
            const liveProducts = [
                "YouTube Standard Membership Pack",
                "YouTube Premium Membership Pack",
                "Facebook Basic Growth Package",
                "Facebook Standard Monetizer Package",
                "Banglalink 100 GB + 380 Min Combo",
                "Banglalink 20 GB Internet Offer",
                "Grameenphone 58 GB + 80 Min Pack",
