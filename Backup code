                        return;
                    }
                    if (Object.keys(this.telecomErrors).length === 0) {
                        this.isTelecomSubmitting = true;
                        const finalPrice = this.calcCheckoutPrice(this.checkoutOffer.basePrice, this.telecomPromo);
                        const product = `${this.currentSlug} - ${this.checkoutOffer.data}`;
