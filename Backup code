                "Airtel 60 GB Big Data Pack",
                "Free Fire 1270 Diamond Full Level Up",
                "Free Fire Weekly Subscription",
                "Free Fire Monthly Membership Package"
            ];

            const timePhrases = ["Just now", "2 seconds ago", "15 seconds ago", "40 seconds ago", "1 minute ago"];
            const toastContainer = document.getElementById('toast-container');

            function showLiveNotification() {
                if (!toastContainer) return;

                // Alpine.js এর বর্তমান পেজ চেক করা হচ্ছে (হোয়াটসঅ্যাপ এন্ট্রি ভিউতে নোটিফিকেশন বন্ধ রাখার জন্য)
                const bodyEl = document.querySelector('body');
                if (bodyEl && bodyEl.__x && bodyEl.__x.$data) {
                    const currentPage = bodyEl.__x.$data.currentPage;
                    if (currentPage === 'whatsapp-entry') {
                        // হোয়াটসঅ্যাপ পেজে থাকলে নোটিফিকেশন দেখাবে না, ৮-১৫ সেকেন্ড পর আবার চেক করবে
                        let retryDelay = Math.floor(Math.random() * (15000 - 8000 + 1)) + 8000;
                        setTimeout(showLiveNotification, retryDelay);
                        return;
                    }
                }

                const randomName = customerNames[Math.floor(Math.random() * customerNames.length)];
                const randomPrefix = phonePrefixes[Math.floor(Math.random() * phonePrefixes.length)];
                const randomDigits = Math.floor(1000 + Math.random() * 9000);
                const randomProduct = liveProducts[Math.floor(Math.random() * liveProducts.length)];
                const randomTime = timePhrases[Math.floor(Math.random() * timePhrases.length)];
                const randomOrderId = Math.floor(1000 + Math.random() * 9000);

                const toast = document.createElement('div');
                toast.className = "pointer-events-auto w-full max-w-sm bg-zinc-900/95 backdrop-blur-md border border-emerald-500/30 text-white p-3.5 rounded-xl shadow-2xl transform translate-y-4 opacity-0 transition-all duration-500 flex items-center gap-3";
                
                toast.innerHTML = `
                    <div class="w-9 h-9 bg-emerald-600/20 text-emerald-400 rounded-full flex items-center justify-center text-sm border border-emerald-500/20 shrink-0">
                        <i class="fas fa-shopping-bag animate-pulse"></i>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex items-center justify-between gap-2">
                            <p class="text-xs font-bold text-white truncate">${randomName} (${randomPrefix}***${randomDigits})</p>
                            <span class="text-[10px] bg-zinc-800 text-emerald-400 px-1.5 py-0.5 rounded font-mono shrink-0">ID: #${randomOrderId}</span>
                        </div>
                        <p class="text-[11px] text-zinc-300 font-medium mt-1">${randomProduct} সফলভাবে কিনেছেন</p>
                        <span class="text-[9px] text-zinc-500 block mt-1"><i class="far fa-clock mr-1"></i>${randomTime}</span>
                    </div>
                    <button class="text-zinc-500 hover:text-zinc-300 transition shrink-0 self-start" onclick="this.parentElement.remove()">
                        <i class="fas fa-times text-xs"></i>
                    </button>
                `;

                toastContainer.appendChild(toast);

                setTimeout(() => {
                    toast.classList.remove('translate-y-4', 'opacity-0');
                }, 100);

                setTimeout(() => {
                    toast.classList.add('opacity-0', 'translate-y-2');
                    setTimeout(() => { toast.remove(); }, 500);
                }, 4500);

                // রিয়েল হিউম্যান রিদম টাইমিং লজিক (পরবর্তী নোটিফিকেশনগুলোর জন্য)
                let nextRandomDelay;
                const diceRoll = Math.random();

                if (diceRoll < 0.15) {
                    nextRandomDelay = Math.floor(Math.random() * (5000 - 4000 + 1)) + 4000;
                } else if (diceRoll < 0.35) {
                    nextRandomDelay = Math.floor(Math.random() * (20000 - 15000 + 1)) + 15000;
                } else {
                    nextRandomDelay = Math.floor(Math.random() * (70000 - 40000 + 1)) + 40000;
                }

                setTimeout(showLiveNotification, nextRandomDelay);
            }

            // প্রথম নোটিফিকেশন ৮ থেকে ১৫ সেকেন্ডের মধ্যে যেকোনো একটি সময়ে আসবে
            const initialDelay = Math.floor(Math.random() * (15000 - 8000 + 1)) + 8000;
            setTimeout(showLiveNotification, initialDelay);
        });
