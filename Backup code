                initMaster() {
                    this.parseGlobalConfig();
                    
                    const wpAuthTimestamp = localStorage.getItem('wp_auth_success_time');
                    if (wpAuthTimestamp) {
                        const hoursPassed = (Date.now() - parseInt(wpAuthTimestamp)) / (1000 * 60 * 60);
                        if (hoursPassed < 24) {
                            this.currentPage = 'home'; 
                        } else {
                            localStorage.removeItem('wp_auth_success_time'); 
                        }
                    }

                    lucide.createIcons();
