<!DOCTYPE html>
<html lang="bn" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PromoShop - Premium Services</title>

    <script>
        // ==================== GLOBAL CONFIGURATION ====================
        const globalDiscountConfig = "on-35"; 
        // ==============================================================
    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;600;700&display=swap" rel="stylesheet">
    
    <style>
        /* ===== ALL STYLES ===== */
        :root {
            --background: 0 0% 100%;
            --foreground: 0 0% 3.9%;
            --card: 0 0% 100%;
            --card-foreground: 0 0% 3.9%;
            --primary: 0 0% 9%;
            --primary-foreground: 0 0% 98%;
            --border: 0 0% 89.8%;
            --radius: 0.5rem;
        }

        .dark {
            --background: 0 0% 3.9%;
            --foreground: 0 0% 98%;
            --card: 0 0% 11%;
            --card-foreground: 0 0% 98%;
            --border: 0 0% 14.9%;
        }

        * { box-sizing: border-box; margin: 0; padding: 0; }

        body {
            background-color: #1a1a1a !important;
            color: #e0e0e0 !important;
            font-family: 'Hind Siliguri', sans-serif, system-ui;
            padding: 0 !important;
            margin: 0 !important;
        }

        [x-cloak] { display: none !important; }

        .bg-promo-dark-bg { background-color: #1a1a1a; }
        .bg-promo-card-bg { background-color: #242424; }
        .text-promo-text-light { color: #ffffff; }
        .text-promo-text-muted { color: #a0a0a0; }
        .border-promo-red { border-color: #ff3b30; }
        .bg-promo-red-20 { background-color: rgba(255, 59, 48, 0.2); }
        .hover-bg-promo-red-30:hover { background-color: rgba(255, 59, 48, 0.3); }
        .text-promo-red { color: #ff3b30; }
        
        .animate-spin-custom {
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }

        /* Toast Notification Styles */
        .live-toast-notification {
            pointer-events: auto;
            width: 100%;
            max-width: 320px !important;
            background-color: rgba(24, 24, 27, 0.95);
            backdrop-filter: blur(8px);
            -webkit-backdrop-filter: blur(8px);
            border: 1px solid rgba(16, 185, 129, 0.3);
            color: #ffffff;
            padding: 10px 12px !important;
            border-radius: 10px !important;
            box-shadow: 0 20px 25px -5px rgba(0, 0, 0, 0.5), 0 10px 10px -5px rgba(0, 0, 0, 0.4);
            transform: translateY(20px);
            opacity: 0;
            transition: all 0.5s cubic-bezier(0.4, 0, 0.2, 1);
            display: flex;
            align-items: center;
            gap: 8px;
            font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;
            font-size: 11px !important;
        }
        .live-toast-notification.show {
            transform: translateY(0);
            opacity: 1;
        }
        .live-toast-notification.hide {
            transform: translateY(-10px);
            opacity: 0;
        }
        .live-toast-notification .toast-icon {
            width: 28px !important;
            height: 28px !important;
            background-color: rgba(16, 185, 129, 0.15);
            color: #10b981;
            border-radius: 50%;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 11px;
            border: 1px solid rgba(16, 185, 129, 0.2);
            flex-shrink: 0;
        }
        .live-toast-notification .toast-name { margin: 0; font-size: 11px; font-weight: bold; color: #ffffff; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
        .live-toast-notification .toast-id { margin: 0; font-size: 8px; background-color: #27272a; color: #10b981; padding: 1px 5px; border-radius: 3px; font-family: monospace; flex-shrink: 0; }
        .live-toast-notification .toast-product { margin: 2px 0 0 0; font-size: 10px; color: #d4d4d8; font-weight: 500; line-height: 1.3; }
        .live-toast-notification .toast-time { margin: 2px 0 0 0; font-size: 8px; color: #71717a; display: block; }
        .live-toast-notification .toast-close { background: none; border: none; color: #52525b; cursor: pointer; padding: 0; flex-shrink: 0; align-self: flex-start; font-size: 10px; transition: color 0.2s; }
        .live-toast-notification .toast-close:hover { color: #d4d4d8; }

        /* Payment Page */
        .payment-page-wrapper {
            position: fixed !important;
            top: 0 !important;
            left: 0 !important;
            right: 0 !important;
            bottom: 0 !important;
            width: 100vw !important;
            height: 100vh !important;
            max-width: 100% !important;
            max-height: 100% !important;
            padding: 0 !important;
            margin: 0 !important;
            background: #ffffff !important;
            border-radius: 0 !important;
            overflow: hidden !important;
            z-index: 99999 !important;
        }
        .payment-page-wrapper iframe {
            width: 100% !important;
            height: 100% !important;
            border: none !important;
            display: block !important;
        }
        body.payment-mode {
            overflow: hidden !important;
            padding: 0 !important;
            margin: 0 !important;
            background: #ffffff !important;
        }
        body.payment-mode #main-header-container,
        body.payment-mode .w-full.max-w-md:not(.payment-page-wrapper) {
            display: none !important;
        }
        body.payment-mode .min-h-screen {
            padding: 0 !important;
            margin: 0 !important;
        }

        /* Scrolling Headline */
        .scrolling-headline {
            overflow: hidden;
            white-space: nowrap;
            background: rgba(220, 38, 38, 0.08);
            border: 1px solid rgba(220, 38, 38, 0.25);
            border-radius: 8px;
            padding: 6px 10px;
            display: flex;
            align-items: center;
            gap: 8px;
        }
        .scrolling-headline .static-text {
            flex-shrink: 0;
            color: #fbbf24;
            font-weight: 800;
            font-size: 11px;
        }
        .scrolling-headline .scroll-track {
            overflow: hidden;
            flex: 1;
            position: relative;
        }
        .scrolling-headline .scroll-content {
            display: inline-block;
            white-space: nowrap;
            animation: scrollMarquee 15s linear infinite;
            color: #fca5a5;
            font-size: 11px;
            font-weight: 700;
        }
        @keyframes scrollMarquee {
            0% { transform: translateX(100%); }
            100% { transform: translateX(-100%); }
        }

        /* Sidebar Menu */
        .sidebar-overlay {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: rgba(0,0,0,0.6);
            z-index: 99998;
            opacity: 0;
            pointer-events: none;
            transition: opacity 0.3s ease;
        }
        .sidebar-overlay.active {
            opacity: 1;
            pointer-events: all;
        }
        .sidebar-menu {
            position: fixed;
            top: 0;
            right: -320px;
            width: 300px;
            height: 100vh;
            background: #1e1e1e;
            z-index: 99999;
            transition: right 0.3s cubic-bezier(0.4, 0, 0.2, 1);
            padding: 20px;
            border-left: 1px solid #333;
            overflow-y: auto;
        }
        .sidebar-menu.open {
            right: 0;
        }
        .sidebar-menu .close-btn {
            position: absolute;
            top: 15px;
            right: 15px;
            color: #888;
            font-size: 20px;
            cursor: pointer;
            background: none;
            border: none;
        }
        .sidebar-menu .close-btn:hover { color: #fff; }
        .sidebar-menu .user-info {
            display: flex;
            align-items: center;
            gap: 12px;
            padding: 15px 0;
            border-bottom: 1px solid #333;
            margin-bottom: 15px;
        }
        .sidebar-menu .user-info .avatar {
            width: 50px;
            height: 50px;
            border-radius: 50%;
            background: #2d2d2d;
            display: flex;
            align-items: center;
            justify-content: center;
            font-size: 24px;
            color: #10b981;
            border: 2px solid #10b981;
        }
        .sidebar-menu .user-info .avatar.admin-avatar {
            background: #1a1a1a;
            border-color: #10b981;
            font-size: 22px;
            font-weight: 700;
            color: #10b981;
        }
        .sidebar-menu .user-info .name { color: #fff; font-weight: 600; font-size: 14px; }
        .sidebar-menu .user-info .phone { color: #888; font-size: 12px; }
        .sidebar-menu .menu-item {
            display: flex;
            align-items: center;
            gap: 14px;
            padding: 12px 14px;
            color: #ccc;
            border-radius: 10px;
            cursor: pointer;
            transition: all 0.2s;
            font-size: 14px;
            text-decoration: none;
        }
        .sidebar-menu .menu-item:hover { background: #2d2d2d; color: #fff; }
        .sidebar-menu .menu-item i { width: 20px; color: #10b981; }
        .sidebar-menu .menu-item.danger { color: #ef4444; }
        .sidebar-menu .menu-item.danger i { color: #ef4444; }
        .sidebar-menu .menu-item .badge {
            background: #10b981;
            color: white;
            font-size: 9px;
            padding: 1px 8px;
            border-radius: 10px;
            margin-left: auto;
        }

        /* Loading Screen */
        .loading-screen {
            position: fixed;
            top: 0;
            left: 0;
            right: 0;
            bottom: 0;
            background: #1a1a1a;
            z-index: 999999;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            transition: opacity 0.8s ease, visibility 0.8s ease;
        }
        .loading-screen.hide {
            opacity: 0;
            visibility: hidden;
            pointer-events: none;
        }
        .loading-screen .loader {
            width: 60px;
            height: 60px;
            border: 4px solid #2d2d2d;
            border-top: 4px solid #ef4444;
            border-radius: 50%;
            animation: spin 0.8s linear infinite;
        }
        .loading-screen .logo-text {
            color: #fff;
            font-size: 28px;
            font-weight: 800;
            margin-top: 20px;
            letter-spacing: 2px;
        }
        .loading-screen .logo-text span { color: #ef4444; }
        .loading-screen .sub-text {
            color: #888;
            font-size: 13px;
            margin-top: 8px;
            letter-spacing: 3px;
            animation: pulse 1.5s ease-in-out infinite;
        }
        @keyframes pulse { 0%, 100% { opacity: 0.4; } 50% { opacity: 1; } }

        /* Login Page */
        .login-page {
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            background: #0d0d0d;
            padding: 20px;
        }
        .login-container {
            background: #1a1a1a;
            padding: 30px;
            border-radius: 16px;
            box-shadow: 0 8px 30px rgba(0,0,0,0.5);
            width: 100%;
            max-width: 450px;
            border: 1px solid #2d2d2d;
        }
        .login-container h2 { text-align: center; margin-bottom: 25px; color: #ffffff; font-weight: 600; }
        .login-container h2 span { color: #ef4444; }
        .login-container .tab {
            display: flex;
            gap: 10px;
            margin-bottom: 25px;
            border-bottom: 2px solid #2d2d2d;
            padding-bottom: 10px;
        }
        .login-container .tab button {
            flex: 1;
            padding: 10px 0;
            border: none;
            background: transparent;
            font-size: 16px;
            font-weight: 600;
            color: #888;
            cursor: pointer;
            border-radius: 40px;
            transition: 0.3s;
        }
        .login-container .tab button.active {
            background: #ef4444;
            color: white;
            box-shadow: 0 4px 12px rgba(239, 68, 68, 0.3);
        }
        .login-container .tab button:hover { background: #2d2d2d; color: #fff; }
        .login-container .tab button.active:hover { background: #dc2626; }
        .login-container .form-group { margin-bottom: 16px; }
        .login-container .form-group label {
            display: block;
            margin-bottom: 6px;
            font-weight: 500;
            color: #ccc;
            font-size: 13px;
        }
        .login-container .form-group input {
            width: 100%;
            padding: 12px 16px;
            border: 1.5px solid #2d2d2d;
            border-radius: 10px;
            font-size: 14px;
            transition: 0.3s;
            background: #0d0d0d;
            color: #fff;
        }
        .login-container .form-group input:focus {
            border-color: #ef4444;
            outline: none;
            background: #1a1a1a;
            box-shadow: 0 0 0 4px rgba(239, 68, 68, 0.15);
        }
        .login-container .form-group input.error {
            border-color: #dc3545 !important;
            background: rgba(220, 53, 69, 0.1) !important;
        }
        .login-container .btn {
            width: 100%;
            padding: 14px;
            background: #ef4444;
            color: white;
            border: none;
            border-radius: 40px;
            font-size: 16px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
            margin-top: 8px;
        }
        .login-container .btn:hover {
            background: #dc2626;
            transform: translateY(-2px);
            box-shadow: 0 8px 20px rgba(239, 68, 68, 0.3);
        }
        .login-container .btn:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
        .login-container .message {
            margin-top: 16px;
            padding: 10px 16px;
            border-radius: 10px;
            display: none;
            text-align: center;
            font-weight: 500;
            font-size: 13px;
        }
        .login-container .message.success {
            display: block;
            background: rgba(16, 185, 129, 0.15);
            color: #34d399;
            border: 1px solid rgba(16, 185, 129, 0.2);
        }
        .login-container .message.error {
            display: block;
            background: rgba(239, 68, 68, 0.15);
            color: #f87171;
            border: 1px solid rgba(239, 68, 68, 0.2);
        }
        .login-container .message.info {
            display: block;
            background: rgba(59, 130, 246, 0.15);
            color: #60a5fa;
            border: 1px solid rgba(59, 130, 246, 0.2);
        }
        .login-container .divider {
            display: flex;
            align-items: center;
            margin: 20px 0;
            color: #666;
            font-size: 13px;
        }
        .login-container .divider::before,
        .login-container .divider::after {
            content: "";
            flex: 1;
            height: 1px;
            background: #2d2d2d;
        }
        .login-container .divider::before { margin-right: 15px; }
        .login-container .divider::after { margin-left: 15px; }
        .login-container .switch-link {
            text-align: center;
            margin-top: 16px;
            color: #888;
            font-size: 13px;
        }
        .login-container .switch-link a {
            color: #ef4444;
            font-weight: 600;
            cursor: pointer;
            text-decoration: none;
        }
        .login-container .switch-link a:hover { text-decoration: underline; }
        .login-container .hidden { display: none !important; }
        .login-container .user-status {
            text-align: center;
            padding: 20px;
            background: rgba(16, 185, 129, 0.1);
            border-radius: 12px;
            margin-bottom: 20px;
            border: 1px solid rgba(16, 185, 129, 0.2);
        }
        .login-container .user-status .name { font-size: 18px; font-weight: 600; color: #34d399; }
        .login-container .user-status .email { color: #888; margin-top: 5px; font-size: 13px; }
        .login-container .logout-btn { background: #dc3545; margin-top: 10px; }
        .login-container .logout-btn:hover { background: #c82333; }
        .login-container .back-to-app {
            display: block;
            text-align: center;
            margin-top: 15px;
            color: #888;
            font-size: 13px;
            cursor: pointer;
            transition: 0.3s;
        }
        .login-container .back-to-app:hover { color: #fff; }
        .login-container .back-to-app i { margin-right: 6px; }

        .main-container { padding-top: 10px; padding-bottom: 4px; }
        .header-gap-top { margin-top: 6px; }
        .header-gap-bottom { margin-bottom: 6px; }

        /* Order History - Green Theme */
        .order-item {
            background: rgba(16, 185, 129, 0.05);
            border: 1px solid rgba(16, 185, 129, 0.2);
            border-radius: 12px;
            padding: 14px 16px;
            margin-bottom: 10px;
            transition: all 0.3s;
        }
        .order-item:hover {
            border-color: rgba(16, 185, 129, 0.5);
        }
        .order-item .order-header {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
        }
        .order-item .order-id { color: #10b981; font-weight: 700; font-size: 13px; }
        .order-item .order-date { color: #666; font-size: 10px; }
        .order-item .order-product { color: #fff; font-size: 14px; font-weight: 500; margin-top: 4px; }
        .order-item .order-amount { color: #fbbf24; font-weight: 700; font-size: 15px; }
        .order-item .order-status {
            background: rgba(16, 185, 129, 0.2);
            color: #10b981;
            font-size: 10px;
            padding: 2px 10px;
            border-radius: 12px;
            font-weight: 600;
        }
        .order-item .order-delete {
            background: none;
            border: none;
            color: #ef4444;
            cursor: pointer;
            font-size: 13px;
            padding: 4px 6px;
            border-radius: 6px;
            transition: 0.2s;
        }
        .order-item .order-delete:hover { background: rgba(239, 68, 68, 0.15); }
        .order-item .order-details {
            margin-top: 8px;
            padding-top: 8px;
            border-top: 1px solid rgba(16, 185, 129, 0.15);
            font-size: 11px;
            color: #888;
        }
        .order-item .order-details .detail-row {
            display: flex;
            gap: 6px;
            padding: 1px 0;
        }
        .order-item .order-details .detail-key { color: #666; }
        .order-item .order-details .detail-value { color: #ccc; }

        .profile-stats {
            display: grid;
            grid-template-columns: 1fr 1fr;
            gap: 10px;
            margin: 15px 0;
        }
        .profile-stats .stat-box {
            background: #1a1a1a;
            border: 1px solid #2d2d2d;
            border-radius: 10px;
            padding: 12px;
            text-align: center;
        }
        .profile-stats .stat-box .number { font-size: 20px; font-weight: 700; color: #10b981; }
        .profile-stats .stat-box .label { font-size: 10px; color: #666; margin-top: 2px; }

        /* Support Page */
        .support-card {
            background: #1a1a1a;
            border: 1px solid #2d2d2d;
            border-radius: 12px;
            padding: 16px;
            margin-bottom: 12px;
        }
        .support-card .title { color: #fff; font-weight: 600; font-size: 14px; }
        .support-card .desc { color: #888; font-size: 12px; margin-top: 4px; line-height: 1.5; }
        .support-btn {
            display: inline-flex;
            align-items: center;
            gap: 8px;
            padding: 10px 20px;
            border-radius: 10px;
            border: none;
            font-weight: 600;
            font-size: 13px;
            cursor: pointer;
            transition: 0.3s;
            text-decoration: none;
            color: white;
            margin: 4px;
        }
        .support-btn.whatsapp { background: #25D366; }
        .support-btn.whatsapp:hover { background: #1da851; transform: translateY(-2px); }
        .support-btn.telegram { background: #0088cc; }
        .support-btn.telegram:hover { background: #006699; transform: translateY(-2px); }
        .support-btn i { font-size: 18px; }
    </style>
</head>
<body x-data="promoShopMaster()" x-init="initMaster()" class="min-h-screen flex flex-col items-center justify-center bg-promo-dark-bg">

    <!-- Loading Screen -->
    <div id="loadingScreen" class="loading-screen">
        <div class="loader"></div>
        <div class="logo-text">PROMO <span>SHOP</span></div>
        <div class="sub-text">Loading your experience...</div>
    </div>

    <!-- Sidebar Overlay -->
    <div class="sidebar-overlay" :class="sidebarOpen ? 'active' : ''" @click="sidebarOpen = false"></div>

    <!-- Sidebar Menu -->
    <div class="sidebar-menu" :class="sidebarOpen ? 'open' : ''">
        <button class="close-btn" @click="sidebarOpen = false">✕</button>
        
        <div class="user-info">
            <div class="avatar" x-show="!isAdmin">👤</div>
            <div class="avatar admin-avatar" x-show="isAdmin">@</div>
            <div>
                <div class="name" x-text="userName || 'Guest User'"></div>
                <div class="phone" x-text="userPhone || 'Not logged in'"></div>
            </div>
        </div>

        <div class="menu-item" @click="sidebarOpen = false; navigateTo('home')">
            <i class="fas fa-home"></i> Home
        </div>
        <div class="menu-item" @click="sidebarOpen = false; navigateTo('order-history')">
            <i class="fas fa-history"></i> Order History
            <span class="badge" x-show="orderHistory.length > 0" x-text="orderHistory.length"></span>
        </div>
        <div class="menu-item" @click="sidebarOpen = false; navigateTo('profile-settings')">
            <i class="fas fa-user-cog"></i> Profile Settings
        </div>
        <div class="menu-item" @click="sidebarOpen = false; navigateTo('support')">
            <i class="fas fa-headset"></i> Support
        </div>
        <div class="menu-item danger" @click="handleLogout()">
            <i class="fas fa-sign-out-alt"></i> Logout
        </div>
    </div>

    <!-- ============================================================ -->
    <!-- ==================== LOGIN / REGISTER PAGE ================== -->
    <!-- ============================================================ -->
    <div x-cloak x-show="currentPage === 'login'" class="w-full max-w-md login-page" id="loginPageContainer">
        <div class="login-container">
            <h2>🔐 <span>Promo</span>Shop</h2>

            <div class="tab">
                <button id="registerTab" class="active" onclick="window.showRegister()">📝 Register</button>
                <button id="loginTab" onclick="window.showLogin()">🔑 Login</button>
            </div>

            <div id="userStatus" class="hidden">
                <div class="user-status">
                    <div class="name" id="loggedUserName">User</div>
                    <div class="email" id="loggedUserEmail">email@example.com</div>
                    <button class="btn logout-btn" onclick="window.logoutUser()">🚪 Logout</button>
                </div>
            </div>

            <div id="registerForm">
                <div class="form-group">
                    <label>👤 Name</label>
                    <input type="text" id="regName" placeholder="Enter your name" required>
                </div>
