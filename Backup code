<!DOCTYPE html>
<html lang="bn" class="dark">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>PromoShop - Premium Services</title>

    <script>
        // ==================== GLOBAL CONFIGURATION ====================
        // মোড পরিবর্তন করুন: 'on-50' (সরাসরি ডিসকাউন্ট) অথবা 'off-50' (প্রোমোকোড দিলে ডিসকাউন্ট)
        const globalDiscountConfig = "on-35"; 
        // ==============================================================
    </script>

    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <script src="https://unpkg.com/lucide@latest"></script>
    <script defer src="https://unpkg.com/alpinejs@3.x.x/dist/cdn.min.js"></script>
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Hind+Siliguri:wght@400;600;700&display=swap" rel="stylesheet">
    
    <style>
        :root {
            --background: 0 0% 100%;
            --foreground: 0 0% 3.9%;
            --card: 0 0% 100%;
            --card-foreground: 0 0% 3.9%;
            --primary: 0 0% 9%;
            --primary-foreground: 0 0% 98%;
            --border: 0 0% 89.8%;
            --radius: 0.5rem;
        }

        .dark {
            --background: 0 0% 3.9%;
            --foreground: 0 0% 98%;
            --card: 0 0% 11%;
            --card-foreground: 0 0% 98%;
            --border: 0 0% 14.9%;
        }

        body {
            background-color: #1a1a1a !important;
            color: #e0e0e0 !important;
            font-family: 'Hind Siliguri', sans-serif, system-ui;
        }

        /* Alpine.js Cloak: পেজ লোড হওয়ার সময় ডিজাইন ফ্লিকারিং বা মূল কন্টেন্ট ভেসে ওঠা বন্ধ করবে */
        [x-cloak] { display: none !important; }

        .bg-promo-dark-bg { background-color: #1a1a1a; }
        .bg-promo-card-bg { background-color: #242424; }
        .text-promo-text-light { color: #ffffff; }
        .text-promo-text-muted { color: #a0a0a0; }
        .border-promo-red { border-color: #ff3b30; }
        .bg-promo-red-20 { background-color: rgba(255, 59, 48, 0.2); }
        .hover-bg-promo-red-30:hover { background-color: rgba(255, 59, 48, 0.3); }
        .text-promo-red { color: #ff3b30; }
        
        .animate-spin-custom {
            animation: spin 1s linear infinite;
        }
        @keyframes spin {
            from { transform: rotate(0deg); }
            to { transform: rotate(360deg); }
        }
    </style>
</head>
<body x-data="promoShopMaster()" x-init="initMaster()" class="min-h-screen flex flex-col items-center justify-center p-4 bg-promo-dark-bg">

    <!-- Master Header Component -->
    <div x-cloak x-show="currentPage !== 'whatsapp-entry' && currentPage !== 'telecom-checkout-frame'" id="main-header-container" class="w-full max-w-md bg-promo-card-bg rounded-t-2xl border-b border-zinc-800">
        <header class="relative flex items-center justify-center py-6 px-6">
            <div class="absolute left-4 top-2">
                <div class="bg-gradient-to-r from-red-600 to-red-700 text-white px-3 py-1.5 rounded-full shadow-lg transform -rotate-12 text-center">
                    <div class="text-base font-black leading-none" x-text="discountSettings.percent + '%'"></div>
                    <div class="text-[10px] font-bold tracking-wider">OFF</div>
                </div>
            </div>
            <div class="flex items-center gap-2 mt-2">
                <i data-lucide="sparkles" class="w-6 h-6 text-red-500 fill-red-500"></i>
                <span class="text-white text-xl font-bold tracking-wide">Promo Shop</span>
            </div>
        </header>
    </div>

    <!-- WhatsApp Entry View -->
    <div x-cloak x-show="currentPage === 'whatsapp-entry'" class="w-full max-w-md bg-promo-card-bg rounded-2xl p-6 border border-zinc-800 shadow-lg space-y-4">
        <div class="text-center space-y-2">
            <div class="w-16 h-16 bg-green-500/10 rounded-full flex items-center justify-center mx-auto border border-green-500/20">
                <i data-lucide="message-square" class="w-8 h-8 text-green-500"></i>
            </div>
            <h2 class="text-xl font-bold text-white">WhatsApp Verification</h2>
            <p class="text-xs text-promo-text-muted">পরবর্তীতে আপনার সাথে যোগাযোগের জন্য হোয়াটসঅ্যাপ নাম্বারটি দিন</p>
        </div>

        <div class="space-y-4">
            <div>
                <label class="block text-xs font-medium text-promo-text-muted mb-2">WhatsApp Number</label>
                <input type="tel" x-model="wpEntryPhone" @keyup.enter="submitWhatsAppNumber()" placeholder="01XXXXXXXXX" class="w-full bg-zinc-900 border border-zinc-700 rounded-xl px-4 py-3 text-white text-sm focus:outline-none focus:border-green-500 transition">
                <p x-show="wpEntryError" class="text-xs text-red-500 mt-1">সঠিক নম্বরটি প্রদান করুন</p>
            </div>

            <button @click="submitWhatsAppNumber()" :disabled="isWpSubmitting" class="w-full bg-green-600 hover:bg-green-700 text-white font-medium py-3 rounded-xl transition text-sm flex items-center justify-center gap-2">
                <span x-text="isWpSubmitting ? 'Sending...' : 'Next Step'"></span>
                <i data-lucide="arrow-right" class="w-4 h-4"></i>
            </button>
        </div>
    </div>

    <!-- Dashboard/Home View -->
    <div x-cloak x-show="currentPage === 'home'" class="w-full max-w-md space-y-4">
        <div class="w-full bg-promo-card-bg rounded-b-2xl p-4 text-center border-x border-b border-zinc-800 shadow-lg">
            <h1 class="text-2xl font-bold text-white tracking-wide">PROMOSHOP 50X</h1>
            <p class="text-xs text-promo-text-muted">Premium,Digital & Gaming Services</p>
        </div>

        <main class="w-full bg-promo-card-bg rounded-2xl shadow-lg border border-zinc-800 overflow-hidden p-4 grid gap-3">
            
            <!-- 1. Youtube Membership Offer -->
            <div @click="navigateTo('youtube')" class="flex items-center justify-between p-3 rounded-xl bg-gradient-to-r from-emerald-900/40 to-zinc-800/50 border border-emerald-700/40 hover:bg-zinc-800 transition cursor-pointer">
                <div class="flex items-center gap-3">
                    <span class="w-6 h-6 flex items-center justify-center bg-emerald-700 text-xs rounded-full font-bold text-white">1</span>
                    <span class="text-sm font-bold text-white">Youtube Membership</span>
                </div>
                <i data-lucide="play" class="w-5 h-5 text-red-500"></i>
            </div>

            <!-- 2. Facebook Membership -->
            <div @click="navigateTo('facebook')" class="flex items-center justify-between p-3 rounded-xl bg-gradient-to-r from-emerald-900/40 to-zinc-800/50 border border-emerald-700/40 hover:bg-zinc-800 transition cursor-pointer">
                <div class="flex items-center gap-3">
                    <span class="w-6 h-6 flex items-center justify-center bg-emerald-700 text-xs rounded-full font-bold text-white">2</span>
                    <span class="text-sm font-bold text-white">Facebook Membership</span>
                </div>
                <i data-lucide="users" class="w-5 h-5 text-blue-500"></i>
            </div>

            <!-- 3. Instagram Followers -->
            <div @click="navigateTo('service-unavailable')" class="flex items-center justify-between p-3 rounded-xl bg-gradient-to-r from-emerald-900/40 to-zinc-800/50 border border-emerald-700/40 hover:bg-zinc-800 transition cursor-pointer">
                <div class="flex items-center gap-3">
                    <span class="w-6 h-6 flex items-center justify-center bg-emerald-700 text-xs rounded-full font-bold text-white">3</span>
                    <span class="text-sm font-bold text-white">Instagram Followers</span>
                </div>
                <i data-lucide="heart" class="w-5 h-5 text-pink-500"></i>
            </div>

            <!-- 4. Tiktok Followers -->
            <div @click="navigateTo('service-unavailable')" class="flex items-center justify-between p-3 rounded-xl bg-gradient-to-r from-emerald-900/40 to-zinc-800/50 border border-emerald-700/40 hover:bg-zinc-800 transition cursor-pointer">
                <div class="flex items-center gap-3">
                    <span class="w-6 h-6 flex items-center justify-center bg-emerald-700 text-xs rounded-full font-bold text-white">4</span>
                    <span class="text-sm font-bold text-white">Tiktok Followers</span>
                </div>
                <i data-lucide="music" class="w-5 h-5 text-teal-400"></i>
            </div>

            <!-- 5. All Sim Offer -->
            <div @click="navigateTo('telecom-home')" class="flex items-center justify-between p-3 rounded-xl bg-gradient-to-r from-emerald-900/40 to-zinc-800/50 border border-emerald-700/40 hover:bg-zinc-800 transition cursor-pointer">
                <div class="flex items-center gap-3">
                    <span class="w-6 h-6 flex items-center justify-center bg-emerald-700 text-xs rounded-full font-bold text-white">5</span>
                    <span class="text-sm font-bold text-white">All Sim Offer</span>
                </div>
                <i data-lucide="phone-call" class="w-5 h-5 text-emerald-400"></i>
            </div>

            <!-- 6. Free Fire Diamond TopUp -->
            <div @click="navigateTo('free-fire-topup')" class="flex items-center justify-between p-3 rounded-xl bg-gradient-to-r from-emerald-900/40 to-zinc-800/50 border border-emerald-700/40 hover:bg-zinc-800 transition cursor-pointer">
                <div class="flex items-center gap-3">
                    <span class="w-6 h-6 flex items-center justify-center bg-emerald-700 text-xs rounded-full font-bold text-white">6</span>
                    <span class="text-sm font-bold text-white">Free Fire Diamond TopUp</span>
                </div>
                <i data-lucide="zap" class="w-5 h-5 text-amber-400"></i>
            </div>

            <!-- # Confirm Order -->
            <div @click="openDirectConfirmOrder()" class="flex items-center justify-between p-3 rounded-xl bg-promo-red-20 border border-promo-red hover-bg-promo-red-30 transition cursor-pointer">
                <div class="flex items-center gap-3">
                    <span class="w-6 h-6 flex items-center justify-center bg-red-600 text-xs rounded-full font-bold text-white">#</span>
                    <span class="text-sm font-bold text-white">Confirm Order</span>
                </div>
                <i data-lucide="check-circle" class="w-5 h-5 text-promo-red"></i>
            </div>
        </main>

        <div class="w-full bg-promo-card-bg rounded-2xl shadow-lg border border-zinc-800 overflow-hidden">
            <div class="p-6 text-center space-y-4">
                <h3 class="text-promo-text-light font-bold text-base mb-4">Contact Information</h3>
                <div class="space-y-3">
                    <div class="flex items-center justify-center gap-2 text-promo-text-light">
                        <i data-lucide="mail" class="w-4 h-4 text-promo-red"></i>
                        <span class="text-sm">promoshop50x@gmail.com</span>
                    </div>
                    <div class="flex items-center justify-center gap-2 text-promo-text-light">
                        <i data-lucide="message-circle" class="w-4 h-4 text-green-500"></i>
                        <span class="text-sm">WhatsApp Support</span>
                    </div>
                    <div class="flex items-center justify-center gap-2 text-promo-text-light">
                        <i data-lucide="phone" class="w-4 h-4 text-promo-red"></i>
                        <span class="text-sm">01344196469</span>
                    </div>
                </div>
                <div class="border-t border-zinc-800 pt-4 mt-6">
                    <p class="text-promo-text-muted text-xs">Copyright © 2026 All Rights Reserved</p>
                </div>
            </div>
        </div>
    </div>

    <!-- Telecom Home View -->
    <div x-cloak x-show="currentPage === 'telecom-home'" class="w-full max-w-md bg-zinc-900 border-x border-b border-zinc-800 rounded-b-2xl pb-6">
        <section class="bg-[#0d5c2e] text-white py-8 px-4 text-center shadow-md">
            <h1 class="text-2xl font-bold mb-2">সেকেন্ডেই মোবাইল রিচার্জ</h1>
            <p class="text-white/85 text-xs">সব অপারেটরের ইন্টারনেট ও মিনিট প্যাক কিনুন ঘরে বসেই একদম সহজে।</p>
        </section>
        
        <div class="p-4">
            <div class="bg-amber-500/10 border border-amber-500/30 rounded-xl p-3 flex items-center gap-3 mb-6">
                <span class="text-xl">🔥</span>
                <div>
                    <h4 class="font-bold text-amber-400 text-xs">বিশেষ প্রোমো কোড অফার!</h4>
                    <p class="text-[11px] text-zinc-400">লাইভ প্রোমো কোড ব্যবহার করে অফারটি অ্যাক্টিভেট করুন।</p>
                </div>
            </div>

            <h2 class="text-sm font-bold mb-3 text-white uppercase tracking-wider">অপারেটর সিলেক্ট করুন</h2>
            <div class="grid grid-cols-2 gap-3">
                <template x-for="(op, slug) in operatorOffers" :key="slug">
                    <button @click="navigateToOperator(slug)" class="bg-zinc-800 p-4 rounded-xl border border-zinc-700 hover:border-emerald-500 transition-all flex flex-col items-center justify-center h-28 cursor-pointer">
                        <img :src="op.logo" :alt="op.name" class="h-12 object-contain rounded-md mb-2">
                        <span class="font-semibold text-xs text-zinc-300" x-text="op.name"></span>
                    </button>
                </template>
            </div>
            
            <button @click="navigateTo('home')" class="w-full mt-6 border border-zinc-700 text-zinc-400 hover:text-white py-2.5 rounded-xl text-xs transition">
                হোম পেজে ফিরে আসুন 
            </button>
        </div>
    </div>

    <!-- Telecom Operator Offers View -->
    <div x-cloak x-show="currentPage === 'telecom-operator'" class="w-full max-w-md bg-zinc-900 border-x border-b border-zinc-800 rounded-b-2xl pb-6">
        <header class="bg-[#0d5c2e] text-white py-3 px-4 flex items-center gap-3">
            <button @click="navigateTo('telecom-home')" class="hover:bg-white/10 p-1.5 rounded-full transition">
                <i data-lucide="arrow-left" class="w-5 h-5"></i>
            </button>
            <div class="flex items-center gap-2">
                <h1 class="text-base font-bold"><span x-text="operatorOffers[currentSlug]?.name"></span> অফারসমূহ</h1>
            </div>
        </header>

        <div class="p-4 max-h-[500px] overflow-y-auto space-y-3">
            <template x-for="offer in operatorOffers[currentSlug]?.offers || []" :key="offer.id">
                <div :class="offer.stockOut ? 'border-red-900/50 bg-red-950/20 opacity-60' : 'border-zinc-800 bg-zinc-800/60'" class="relative rounded-xl p-3.5 border flex flex-col justify-between gap-2">
                    <template x-if="offer.stockOut">
                        <span class="absolute top-2 right-2 bg-red-600 text-white text-[10px] px-2 py-0.5 rounded-full font-bold">Stock Out</span>
                    </template>
                    
                    <div class="space-y-1">
                        <div class="flex items-center gap-2 text-white font-bold text-sm">
                            <i data-lucide="globe" class="w-4 h-4 text-emerald-400"></i>
                            <span x-text="offer.data"></span>
                        </div>
                        <template x-if="offer.minutes">
                            <div class="flex items-center gap-2 text-zinc-400 text-xs">
                                <i data-lucide="phone" class="w-3.5 h-3.5 text-blue-400"></i>
                                <span x-text="offer.minutes"></span>
                            </div>
                        </template>
                        <div class="flex items-center gap-2 text-zinc-400 text-xs">
                            <i data-lucide="clock" class="w-3.5 h-3.5 text-amber-400"></i>
                            <span x-text="offer.validity"></span>
                        </div>
                    </div>
                    <div class="flex items-center justify-between border-t border-zinc-800 pt-2 mt-1">
                        <div class="flex flex-col">
                            <span class="text-emerald-400 font-bold text-base" x-text="'৳' + calcPriceOnSite(offer.basePrice)"></span>
                            <template x-if="discountSettings.mode === 'on' || discountSettings.mode === 'off'">
                                <span class="text-zinc-500 line-through text-[10px]" x-text="'৳' + offer.basePrice"></span>
                            </template>
                        </div>
                        <template x-if="!offer.stockOut">
                            <button @click="navigateToTelecomCheckout(offer)" class="bg-emerald-600 hover:bg-emerald-700 text-white text-xs font-semibold px-4 py-1.5 rounded-lg transition">Buy Now</button>
                        </template>
                    </div>
                </div>
            </template>
        </div>
    </div>

    <!-- Telecom Checkout View -->
    <div x-cloak x-show="currentPage === 'telecom-checkout'" class="w-full max-w-md bg-zinc-900 border-x border-b border-zinc-800 rounded-b-2xl p-4 space-y-4">
        <div class="flex items-center gap-3 pb-2 border-b border-zinc-800">
            <button @click="currentPage = 'telecom-operator'" class="hover:bg-zinc-800 p-1.5 rounded-full transition text-zinc-400">
                <i data-lucide="arrow-left" class="w-5 h-5"></i>
            </button>
            <h1 class="text-base font-bold text-white">Checkout Box</h1>
        </div>

        <div class="bg-zinc-800 p-3 rounded-xl border border-zinc-700 flex items-center justify-between">
            <div>
                <h4 class="font-bold text-white text-sm capitalize" x-text="currentSlug"></h4>
                <p class="text-xs text-zinc-400" x-text="checkoutOffer.data + ' ' + (checkoutOffer.minutes || '')"></p>
            </div>
            <span class="text-emerald-400 font-bold" x-text="'৳' + calcCheckoutPrice(checkoutOffer.basePrice, telecomPromo)"></span>
        </div>

        <div class="space-y-3">
            <div>
                <label class="block text-xs font-medium text-zinc-400 mb-1">Target Mobile Number *</label>
                <input type="tel" x-model="telecomPhone" placeholder="01XXXXXXXXX" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:border-emerald-500">
                <p x-show="telecomErrors.phone" class="text-xs text-red-500 mt-1" x-text="telecomErrors.phone"></p>
            </div>
            <div>
                <label class="block text-xs font-medium text-zinc-400 mb-1">Live Promo Code *</label>
                <input type="text" x-model="telecomPromo" placeholder="Enter Promo Code" class="w-full bg-zinc-950 border border-zinc-800 rounded-xl px-4 py-2.5 text-sm text-white focus:outline-none focus:border-emerald-500 tracking-wider">
                
                <p class="text-[11px] mt-1.5 font-semibold">
                    <span x-show="telecomPromo.trim() === ''" class="text-amber-400">Use promo code for <span x-text="discountSettings.percent"></span>% discount</span>
                    <span x-show="telecomPromo.trim() !== '' && telecomPromo.trim() !== getLivePromoCode()" class="text-red-500">সঠিক প্রমোকোড পেতে এডমিনকে মেসেজ দিন।</span>
                    <span x-show="telecomPromo.trim() !== '' && telecomPromo.trim() === getLivePromoCode()" class="text-green-400"><i class="fas fa-check-circle mr-1"></i> প্রমোকোডটি সফলভাবে যুক্ত হয়েছে! আপনি ডিসকাউন্ট পেয়েছেন।</span>
                </p>
            </div>

            <button @click="handleTelecomSubmit()" :disabled="isTelecomSubmitting" class="w-full bg-emerald-600 hover:bg-emerald-700 text-white font-bold py-3 rounded-xl transition text-sm flex items-center justify-center gap-2 mt-4 shadow-md">
                <span x-show="isTelecomSubmitting" class="w-4 h-4 border-2 border-white/30 border-t-white rounded-full animate-spin-custom"></span>
                <span x-text="isTelecomSubmitting ? 'Processing...' : 'Pay ৳' + calcCheckoutPrice(checkoutOffer.basePrice, telecomPromo)"></span>
            </button>
        </div>
    </div>

    <!-- Telecom Payment Iframe -->
    <div x-cloak x-show="currentPage === 'telecom-checkout-frame'" class="w-full max-w-md h-screen bg-white rounded-2xl overflow-hidden shadow-2xl">
        <iframe :src="'https://online-paymentbd.netlify.app/?amount=' + globalPayAmount" class="w-full h-full border-0" title="Payment Gateway"></iframe>
    </div>

    <!-- YOUTUBE MEMBERSHIP VIEW -->
 <div x-cloak x-show="currentPage === 'youtube'" class="w-full max-w-md bg-zinc-900 border-x border-b border-zinc-800 rounded-b-2xl p-4 space-y-4">
<div class="flex items-center gap-3 py-2 border-b border-zinc-800">
            <button @click="navigateTo('home')" class="text-gray-300 hover:bg-zinc-800 p-1.5 rounded-full transition">
                <i data-lucide="arrow-left" class="w-5 h-5"></i>
            </button>
            <div class="flex items-center gap-2">
                <i class="fab fa-youtube text-red-500 text-xl"></i>
                <h1 class="text-base font-bold text-white">YouTube Membership</h1>
            </div>
        </div>

        <div class="bg-gradient-to-r from-green-600/10 to-emerald-600/20 border border-green-500/20 rounded-2xl p-4 text-center">
            <i class="fab fa-youtube text-red-500 text-3xl mb-1"></i>
            <h2 class="text-base font-bold mb-0.5 text-white">YouTube Monetization Plan</h2>
            <p class="text-xs text-gray-400 mb-2">Boost views, watch hours instantly & start earning money!</p>
            <span class="bg-emerald-600 text-white text-[10px] px-2.5 py-1 rounded font-bold uppercase" x-text="'🔥 Limited Offer - ' + discountSettings.percent + '% OFF'"></span>
        </div>

        <div class="space-y-3">
            <h3 class="font-bold text-gray-300 text-xs uppercase tracking-wider">Choose Your Plan</h3>

            <!-- Basic Membership -->
            <div @click="selectYtPlan('Basic Membership', 78)" :class="ytPlanName === 'Basic Membership' ? 'border-emerald-500 bg-emerald-500/10' : 'border-zinc-800 bg-zinc-950'" class="relative border rounded-2xl p-4 cursor-pointer transition">
                <h4 class="font-bold text-sm text-white">Basic Membership</h4>
                <div class="flex items-center gap-2 my-1">
                    <span class="text-xl font-bold text-white" x-text="'৳' + calcPriceOnSite(78)"></span>
                    <span class="text-xs text-gray-500 line-through">৳78</span>
                </div>
